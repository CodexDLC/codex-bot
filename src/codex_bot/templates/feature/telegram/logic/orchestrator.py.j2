from typing import Any, TYPE_CHECKING, Union
from codex_bot.base import BaseBotOrchestrator, UnifiedViewDTO, ViewResultDTO
from ..ui.ui import {{ class_name }}UI
from ..feature_setting import {{ class_name }}States
from .state_manager import {{ class_name }}StateManager

{% if use_loguru %}
from loguru import logger as log
{% else %}
import logging
log = logging.getLogger(__name__)
{% endif %}

if TYPE_CHECKING:
    from codex_bot.director import Director


class {{ class_name }}Orchestrator(BaseBotOrchestrator[Any]):
    """
    Business logic and navigation for the {{ class_name }} feature.
    """
    def __init__(self):
        super().__init__(expected_state={{ class_name }}States.main)
        self.ui = {{ class_name }}UI()

    async def render_content(
        self,
        director: "Director" | None = None,
        payload: Any = None
    ) -> Union[ViewResultDTO, UnifiedViewDTO]:
        """
        Main logic for rendering feature content.

        Example with Data Fetching & Smart Resolver:
        ```python
        # 1. Fetch data (Returns Envelope: meta + payload)
        raw_data = await director.container.api.get_data(director.user_id)

        # 2. Handle backend-driven navigation
        data = await director.resolve(raw_data)
        if isinstance(data, UnifiedViewDTO):
            return data # Redirected to another scene
        ```
        """
        log.debug(f"{{ class_name }} | Rendering Content | user_id={director.user_id}")

        return self.ui.render_main(payload)

    async def handle_entry(
        self,
        director: "Director",
        payload: Any = None,
    ) -> UnifiedViewDTO:
        """Entry point into the feature. Called by Director on set_scene()."""
        log.debug(f"{{ class_name }} | Action: Entry | user_id={director.user_id}")

        return await self.render(director=director, payload=payload)
