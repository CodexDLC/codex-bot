from aiogram import Router, F
from aiogram.types import CallbackQuery
from aiogram.filters import StateFilter

{% if use_loguru %}
from loguru import logger as log
{% else %}
import logging
log = logging.getLogger(__name__)
{% endif %}

from codex_bot.director import Director
from ..feature_setting import {{ class_name }}States
from ..resources.callbacks import {{ class_name }}Callback

router = Router(name="{{ feature_key }}_router")

@router.callback_query(
    {{ class_name }}Callback.filter(F.action == "action"),
    StateFilter({{ class_name }}States.main)
)
async def handle_action(
    call: CallbackQuery,
    callback_data: {{ class_name }}Callback,
    state,
    container,
):
    await call.answer()
    log.info(f"Feature '{{ feature_key }}' action triggered by user {call.from_user.id}")

    director = Director(
        container=container,
        state=state,
        user_id=call.from_user.id,
        chat_id=call.message.chat.id if call.message else None,
    )
    view_dto = await director.set_scene("{{ feature_key }}", payload=callback_data)

    if view_dto and hasattr(container, "view_sender"):
        await container.view_sender.send(view_dto)
