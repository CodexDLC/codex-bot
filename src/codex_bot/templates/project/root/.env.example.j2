# --- Base Infrastructure ---
BOT_TOKEN=your_bot_token_here
SECRET_KEY={{ project_name }}_secret_salt_12345
DEBUG=True

# --- Service Flags ---
USE_REDIS={{ use_redis | lower }}
USE_REDIS_FSM={{ use_redis_fsm | lower }}
USE_REDIS_STREAMS={{ use_redis_streams | lower }}

{% if use_redis %}
# Redis Connection
REDIS_URL=redis://localhost:6379/0
{% endif %}

# --- Access Control ---
# Comma-separated lists of Telegram IDs
SUPERUSER_IDS=
OWNER_IDS=

{% if data_mode == 'api' %}
# --- API Mode Configuration ---
BACKEND_API_URL=https://api.example.com
BACKEND_API_KEY=
BACKEND_API_TIMEOUT=10.0
{% elif data_mode == 'direct' %}
# --- Direct DB Configuration (SQLAlchemy) ---
# Default: SQLite (aiosqlite)
DATABASE_URL=sqlite+aiosqlite:///./bot.db
# To use PostgreSQL, set DATABASE_URL to your connection string
DATABASE_ECHO=False
{% endif %}
