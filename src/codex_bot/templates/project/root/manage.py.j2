#!/usr/bin/env python
"""
{{ project_name | title }} Management Script.
Provides a unified interface for running the bot and managing migrations.
"""

import argparse
import os
import sys
import subprocess
from pathlib import Path

def setup_python_path():
    """Adds the 'src' directory to the Python path."""
    src_path = Path(__file__).parent / "src"
    if str(src_path) not in sys.path:
        sys.path.insert(0, str(src_path))

def run_app(args):
    """Starts the Telegram bot."""
    setup_python_path()
    try:
        from {{ project_name }}.launcher import run
        run()
    except ImportError as e:
        print(f"❌ Error: Could not import the package '{{ project_name }}'.")
        print(f"Details: {e}")
        sys.exit(1)

def makemigrations(args):
    """Generates a new database migration."""
    print(f"🚀 Generating migrations for {{ project_name }}...")

    # Path to alembic.ini inside the package
    config_path = Path("src") / "{{ project_name }}" / "alembic.ini"

    cmd = ["alembic", "-c", str(config_path), "revision", "--autogenerate"]
    if args.message:
        cmd.extend(["-m", args.message])

    try:
        subprocess.run(cmd, check=True)
        print("✅ Migration generated successfully!")
    except subprocess.CalledProcessError:
        sys.exit(1)

def migrate(args):
    """Applies pending migrations."""
    print(f"🚀 Applying migrations for {{ project_name }}...")

    config_path = Path("src") / "{{ project_name }}" / "alembic.ini"

    cmd = ["alembic", "-c", str(config_path), "upgrade", args.revision]

    try:
        subprocess.run(cmd, check=True)
        print("✅ Database is up to date!")
    except subprocess.CalledProcessError:
        sys.exit(1)

def main():
    parser = argparse.ArgumentParser(description="{{ project_name | title }} Management Tool")
    subparsers = parser.add_subparsers(dest="command", required=True)

    # Command: run
    run_parser = subparsers.add_parser("run", help="Start the Telegram bot")
    run_parser.set_defaults(func=run_app)

    {% if data_mode == 'direct' %}
    # Command: makemigrations
    mm_parser = subparsers.add_parser("makemigrations", help="Create a new DB migration")
    mm_parser.add_argument("message", nargs="?", help="Migration comment")
    mm_parser.set_defaults(func=makemigrations_command if 'makemigrations_command' in globals() else makemigrations)

    # Command: migrate
    m_parser = subparsers.add_parser("migrate", help="Apply migrations to DB")
    m_parser.add_argument("revision", nargs="?", default="head", help="Revision to upgrade to")
    m_parser.set_defaults(func=migrate)
    {% endif %}

    args = parser.parse_args()
    args.func(args)

if __name__ == "__main__":
    main()
