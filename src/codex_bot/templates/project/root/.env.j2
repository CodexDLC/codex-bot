# --- Base Infrastructure ---
BOT_TOKEN={{ bot_token }}
SECRET_KEY={{ project_name }}_secret_salt_12345
DEBUG=True

{% if use_redis %}
# Redis Connection
REDIS_URL=redis://localhost:6379/0
{% endif %}

# --- Access Control ---
# Comma-separated lists of Telegram IDs
SUPERUSER_IDS=
OWNER_IDS={{ owner_id }}

{% if data_mode == 'api' %}
# --- API Mode Configuration ---
BACKEND_API_URL=https://api.example.com
BACKEND_API_KEY=
BACKEND_API_TIMEOUT=10.0
{% elif data_mode == 'direct' %}
# --- Direct DB Configuration (SQLAlchemy) ---
# Default Database URL (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./bot.db
DATABASE_ECHO=False
{% endif %}
