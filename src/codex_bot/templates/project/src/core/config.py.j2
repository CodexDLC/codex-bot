from __future__ import annotations

from pydantic import Field
from pydantic_settings import BaseSettings, SettingsConfigDict

class BotSettings(BaseSettings):
    """
    Dynamic configuration for the Telegram Bot '{{ project_name | default('CodexBot') }}'.
    Automatically generated by codex-bot CLI.
    """
    # --- 1. Base Infrastructure ---
    bot_token: str = Field(alias="BOT_TOKEN")
    secret_key: str = Field(alias="SECRET_KEY")
    debug: bool = Field(default=True, alias="DEBUG")

    # Infrastructure Service Flags
    use_redis: bool = Field(default={{ use_redis | lower }}, alias="USE_REDIS")
    use_redis_fsm: bool = Field(default={{ use_redis_fsm | lower }}, alias="USE_REDIS_FSM")
    use_redis_streams: bool = Field(default={{ use_redis_streams | lower }}, alias="USE_REDIS_STREAMS")

    {% if use_redis %}
    # Redis is required for FSM and Stream Processing
    redis_url: str = Field(default="redis://localhost:6379/0", alias="REDIS_URL")
    {% endif %}

    # --- 2. Bot Behavior ---
    {% if use_redis %}
    bot_throttling_rate: float = Field(default=1.0, alias="BOT_THROTTLING_RATE")
    {% endif %}
    bot_allowed_updates: list[str] = Field(
        default=["message", "callback_query", "inline_query"],
        alias="BOT_ALLOWED_UPDATES"
    )

    # --- 3. Access Control ---
    superuser_ids: str = Field(default="", alias="SUPERUSER_IDS")
    owner_ids: str = Field(default="", alias="OWNER_IDS")

    {% if data_mode == 'api' %}
    # --- 4. API Mode Configuration ---
    backend_api_url: str = Field(alias="BACKEND_API_URL")
    backend_api_key: str | None = Field(default=None, alias="BACKEND_API_KEY")
    backend_api_timeout: float = Field(default=10.0, alias="BACKEND_API_TIMEOUT")
    {% elif data_mode == 'direct' %}
    # --- 5. Direct DB Configuration (SQLAlchemy) ---
    database_url: str = Field(
        default="sqlite+aiosqlite:///./bot.db",
        alias="DATABASE_URL"
    )
    database_echo: bool = Field(default=False, alias="DATABASE_ECHO")
    {% endif %}

    @property
    def superuser_ids_list(self) -> list[int]:
        """Helper to convert comma-separated string to list of integers."""
        if not self.superuser_ids:
            return []
        try:
            return [int(x.strip()) for x in self.superuser_ids.split(",") if x.strip()]
        except ValueError:
            return []

    @property
    def owner_ids_list(self) -> list[int]:
        """Helper to convert comma-separated string to list of integers."""
        if not self.owner_ids:
            return []
        try:
            return [int(x.strip()) for x in self.owner_ids.split(",") if x.strip()]
        except ValueError:
            return []

    model_config = SettingsConfigDict(
        env_file=".env",
        env_file_encoding="utf-8",
        extra="ignore",
        populate_by_name=True,
    )
