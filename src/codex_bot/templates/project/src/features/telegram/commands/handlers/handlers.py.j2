from aiogram import Router
from aiogram.filters import CommandStart, Command
from aiogram.types import Message

{% if use_loguru %}
from loguru import logger as log
{% else %}
import logging
log = logging.getLogger(__name__)
{% endif %}

from codex_bot.director import Director

router = Router(name="commands_router")

@router.message(CommandStart())
async def cmd_start(message: Message, director: Director, container):
    """Handles /start command."""
    if not message.from_user:
        return

    log.info(f"Start command received from user {message.from_user.id}")

    orchestrator = container.get_feature("commands")
    view_dto = await orchestrator.handle_entry(director, payload=message.from_user)

    if view_dto and hasattr(container, "view_sender"):
        await container.view_sender.send(view_dto)


@router.message(Command("menu"))
async def cmd_menu(message: Message, director: Director):
    """Direct access to the dashboard."""
    log.debug(f"Menu command received from user {message.from_user.id}")
    await director.set_scene("bot_menu")
